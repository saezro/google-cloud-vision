# Copia a .env y rellena. NO subir .env a git.
# Proyecto GCP aparte para la charla (NO tu-proyecto-gcp).
GCP_PROJECT=charla-vision-demo
GCP_REGION=europe-southwest1
# Bucket donde subimos las imágenes (debe ser único global).
BUCKET=charla-vision-demo-imagenes
# Credenciales: ruta al JSON del service account, o deja vacío si usas
# `gcloud auth application-default login`.
GOOGLE_APPLICATION_CREDENTIALS=
